<!-- Esta fila reemplazará a la fila normal y mostrará el formulario de edición -->
<tr class="edit-mode">
    <td class="text-muted">#<?= $u['id'] ?></td>
    
    <td>
        <!-- Campo Oculto para enviar el ID -->
        <input type="hidden" name="id" value="<?= $u['id'] ?>">
        
        <input type="text" name="nombre" class="form-control" value="<?= htmlspecialchars($u['nombre']) ?>" required>
    </td>
    
    <td>
        <input type="email" name="email" class="form-control" value="<?= htmlspecialchars($u['email']) ?>" required>
    </td>
    
    <td>
        <select name="rol" class="form-control">
            <option value="Admin" <?= $u['rol'] === 'Admin' ? 'selected' : '' ?>>Admin</option>
            <option value="Editor" <?= $u['rol'] === 'Editor' ? 'selected' : '' ?>>Editor</option>
            <option value="User" <?= $u['rol'] === 'User' ? 'selected' : '' ?>>User</option>
        </select>
    </td>
    
    <td>
        <div style="display: flex; gap: 0.5rem;">
            <!-- Botón Guardar envía todos los campos de este tr mediante hx-include -->
            <button class="btn-success"
                    hx-post="/usuarios/guardar"
                    hx-include="closest tr"
                    hx-target="closest tr"
                    hx-swap="outerHTML">
                Guardar
                <span class="htmx-indicator">⏳</span>
            </button>

            <!-- Botón Cancelar vuelve a pedir la fila normal -->
            <button class="btn-cancel"
                    hx-get="/usuarios/fila"
                    hx-vals='{"id": <?= $u['id'] ?>}'
                    hx-target="closest tr"
                    hx-swap="outerHTML">
                Cancelar
            </button>
        </div>
    </td>
</tr>
